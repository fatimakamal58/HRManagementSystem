@model HRManagementSystem.Models.HR.JobTitle

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
	ViewData["Title"] = Localizer["DeleteJobTitle"];
}

<h1>@Localizer["DeleteJobTitle"]</h1>

<h3>@Localizer["ConfirmDelete"]</h3>

<div>
	<h4>@Localizer["JobTitle"]</h4>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">@Localizer["NameAr"]</dt>
		<dd class="col-sm-10">@Model.NameAr</dd>

		<dt class="col-sm-2">@Localizer["NameEn"]</dt>
		<dd class="col-sm-10">@Model.NameEn</dd>

		<dt class="col-sm-2">@Localizer["Active"]</dt>
		<dd class="col-sm-10">@(Model.IsActive ? Localizer["Yes"] : Localizer["No"])</dd>
	</dl>

	<form asp-action="Delete" method="post">
		<input type="hidden" asp-for="Id" />
		<button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
		<a class="btn btn-secondary" asp-action="Index">@Localizer["Cancel"]</a>
	</form>
</div>
