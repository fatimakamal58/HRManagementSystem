@model HRManagementSystem.Domain.Entities.Department

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
	ViewData["Title"] = Localizer["DepartmentDetails"];
}

<h1>@Localizer["DepartmentDetails"]</h1>

<div>
	<h4>@Localizer["Department"]</h4>
	<hr />
	<dl class="row">
		<dt class="col-sm-2">@Localizer["NameAr"]</dt>
		<dd class="col-sm-10">@Model.NameAr</dd>

		<dt class="col-sm-2">@Localizer["NameEn"]</dt>
		<dd class="col-sm-10">@Model.NameEn</dd>

		<dt class="col-sm-2">@Localizer["DescriptionAr"]</dt>
		<dd class="col-sm-10">@Model.DescriptionAr</dd>

		<dt class="col-sm-2">@Localizer["DescriptionEn"]</dt>
		<dd class="col-sm-10">@Model.DescriptionEn</dd>

		<dt class="col-sm-2">@Localizer["Active"]</dt>
		<dd class="col-sm-10">@(Model.IsActive ? Localizer["Yes"] : Localizer["No"])</dd>

		<dt class="col-sm-2">@Localizer["CreatedAt"]</dt>
		<dd class="col-sm-10">@Model.CreatedAt.ToString("u")</dd>
	</dl>

	<a class="btn btn-secondary" asp-action="Index">@Localizer["BackToList"]</a>
	<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">@Localizer["Edit"]</a>
</div>
